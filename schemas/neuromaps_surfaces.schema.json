{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Surfaces",
    "type": "object",
    "description": "Surface files for a brain template, keyed by resolution (e.g. '32k', '164k').",
    "additionalProperties": false,
    "patternProperties": {
        "^[0-9]+k?$": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "pial": {
                    "$ref": "neuromaps_surface-hemi.schema.json"
                },
                "midthickness": {
                    "$ref": "neuromaps_surface-hemi.schema.json"
                },
                "white": {
                    "$ref": "neuromaps_surface-hemi.schema.json"
                },
                "sphere": {
                    "$ref": "neuromaps_surface-hemi.schema.json"
                },
                "inflated": {
                    "$ref": "neuromaps_surface-hemi.schema.json"
                },
                "flat": {
                    "$ref": "neuromaps_surface-hemi.schema.json"
                },
                "annotation": {
                    "type": "object",
                    "description": "Named annotations, each with hemisphere files and optional references.",
                    "additionalProperties": false,
                    "patternProperties": {
                        "^[A-Za-z0-9_]+$": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "left": {
                                    "type": [
                                        "string",
                                        "null"
                                    ],
                                    "format": "uri-reference",
                                    "description": "Surface file for the left hemisphere."
                                },
                                "right": {
                                    "type": [
                                        "string",
                                        "null"
                                    ],
                                    "format": "uri-reference",
                                    "description": "Surface file for the right hemisphere."
                                },
                                "references": {
                                    "oneOf": [
                                        {
                                            "$ref": "neuromaps_references.schema.json"
                                        },
                                        {
                                            "type": "null"
                                        }
                                    ]
                                },
                                "notes": {
                                    "oneOf": [
                                        {
                                            "$ref": "neuromaps_notes.schema.json"
                                        },
                                        {
                                            "type": "null"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
