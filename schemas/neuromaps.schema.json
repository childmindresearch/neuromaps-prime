{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Neuromaps Graph Configuration",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "items": {
                "type": "object",
                "patternProperties": {
                    "^[A-Za-z0-9_]+$": {
                        "type": "object",
                        "properties": {
                            "species": {
                                "type": "string"
                            },
                            "description": {
                                "type": "string"
                            },
                            "surfaces": {
                                "type": "object",
                                "patternProperties": {
                                    "^[0-9]+k?$": {
                                        "type": "object",
                                        "properties": {
                                            "pial": {
                                                "$ref": "#/$defs/surfaceHemisphere"
                                            },
                                            "midthickness": {
                                                "$ref": "#/$defs/surfaceHemisphere"
                                            },
                                            "white": {
                                                "$ref": "#/$defs/surfaceHemisphere"
                                            },
                                            "sphere": {
                                                "$ref": "#/$defs/surfaceHemisphere"
                                            },
                                            "inflated": {
                                                "$ref": "#/$defs/surfaceHemisphere"
                                            },
                                            "flat": {
                                                "$ref": "#/$defs/surfaceHemisphere"
                                            },
                                            "annotation": {
                                                "type": "object",
                                                "patternProperties": {
                                                    "^[A-Za-z0-9_]+$": {
                                                        "$ref": "#/$defs/surfaceHemisphere"
                                                    }
                                                },
                                                "additionalProperties": false
                                            }
                                        },
                                        "additionalProperties": false
                                    }
                                },
                                "additionalProperties": false
                            },
                            "volumes": {
                                "$ref": "#/$defs/volumeDict"
                            }
                        },
                        "required": [
                            "description"
                        ],
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        },
        "edges": {
            "type": "object",
            "properties": {
                "surface_to_surface": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "from": {
                                "type": "string"
                            },
                            "to": {
                                "type": "string"
                            },
                            "surfaces": {
                                "type": "object",
                                "patternProperties": {
                                    "^[A-Za-z0-9_]+$": {
                                        "type": "object",
                                        "patternProperties": {
                                            "^[0-9]+k?$": {
                                                "type": "object",
                                                "properties": {
                                                    "sphere": {
                                                        "$ref": "#/$defs/surfaceHemisphere"
                                                    }
                                                },
                                                "required": [
                                                    "sphere"
                                                ],
                                                "additionalProperties": true
                                            }
                                        },
                                        "additionalProperties": false
                                    }
                                },
                                "additionalProperties": false
                            }
                        },
                        "required": [
                            "from",
                            "to",
                            "surfaces"
                        ],
                        "additionalProperties": false
                    }
                },
                "volume_to_volume": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "from": {
                                "type": "string",
                                "description": "Source node."
                            },
                            "to": {
                                "type": "string",
                                "description": "Target node."
                            },
                            "volumes": {
                                "type": "object",
                                "description": "Transform source.",
                                "patternProperties": {
                                    "^[A-Za-z0-9_]+$": {
                                        "$ref": "#/$defs/volumeDict"
                                    }
                                }
                            }
                        },
                        "required": [
                            "from",
                            "to",
                            "volumes"
                        ],
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "required": [
        "nodes",
        "edges"
    ],
    "additionalProperties": false,
    "$defs": {
        "volumeDict": {
            "type": "object",
            "description": "Dictionary of volume files keyed by resolution and type.",
            "patternProperties": {
                "^[0-9]+(u|m)m$": {
                    "type": "object",
                    "properties": {
                        "annotation": {
                            "patternProperties": {
                                "^[A-Za-z0-9_]+$": {
                                    "type": "string",
                                    "format": "uri-reference",
                                    "description": "URI pointing to an annotation volume file"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "patternProperties": {
                        "^[A-Za-z0-9_]+$": {
                            "type": "string",
                            "format": "uri-reference",
                            "description": "URI pointing to a volume file (e.g., T1w, T2w)"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "surfaceHemisphere": {
            "type": "object",
            "description": "Represents the surface files for both hemispheres of a brain template.",
            "properties": {
                "left": {
                    "type": [
                        "string",
                        null
                    ],
                    "format": "uri-reference",
                    "description": "Surface file for left hemisphere."
                },
                "right": {
                    "type": [
                        "string",
                        null
                    ],
                    "format": "uri-reference",
                    "description": "Surface file for right hemisphere."
                }
            },
            "additionalProperties": false
        }
    }
}
