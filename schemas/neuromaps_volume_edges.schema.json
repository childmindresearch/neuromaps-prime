{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Surface Edges",
    "type": "array",
    "description": "Volume-to-volume registrations between templates.",
    "items": {
        "type": "object",
        "required": [
            "from",
            "to",
            "volumes"
        ],
        "additionalProperties": false,
        "properties": {
            "from": {
                "type": "string",
                "description": "Source node."
            },
            "to": {
                "type": "string",
                "description": "Target node."
            },
            "volumes": {
                "type": "object",
                "description": "Transform source, keyed by name.",
                "additionalProperties": false,
                "properties": {
                    "references": {
                        "oneOf": [
                            {
                                "$ref": "neuromaps_references.schema.json"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    }
                },
                "patternProperties": {
                    "^[A-Za-z0-9_]+$": {
                        "allOf": [
                            {
                                "$ref": "neuromaps_volumes.schema.json"
                            }
                        ]
                    }
                }
            }
        }
    }
}
