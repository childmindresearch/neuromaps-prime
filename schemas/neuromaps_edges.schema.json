{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Edges",
    "type": "object",
    "description": "Transformations between brain template nodes.",
    "additionalProperties": false,
    "properties": {
        "surface_to_surface": {
            "type": "array",
            "description": "Surface-to-surface registrations between templates.",
            "items": {
                "type": "object",
                "required": [
                    "from",
                    "to",
                    "surfaces"
                ],
                "additionalProperties": false,
                "properties": {
                    "from": {
                        "type": "string",
                        "description": "Source node."
                    },
                    "to": {
                        "type": "string",
                        "description": "Target node."
                    },
                    "surfaces": {
                        "type": "object",
                        "description": "Surface registration files, keyed by annotation name then resolution.",
                        "additionalProperties": false,
                        "patternProperties": {
                            "^[A-Za-z0-9_]+$": {
                                "type": "object",
                                "additionalProperties": false,
                                "properties": {
                                    "references": {
                                        "oneOf": [
                                            {
                                                "$ref": "neuromaps_references.schema.json"
                                            },
                                            {
                                                "type": "null"
                                            }
                                        ]
                                    }
                                },
                                "patternProperties": {
                                    "^[0-9]+k?$": {
                                        "type": "object",
                                        "required": [
                                            "sphere"
                                        ],
                                        "additionalProperties": true,
                                        "properties": {
                                            "sphere": {
                                                "$ref": "neuromaps_surface-hemi.schema.json"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "volume_to_volume": {
            "type": "array",
            "description": "Volume-to-volume registrations between templates.",
            "items": {
                "type": "object",
                "required": [
                    "from",
                    "to",
                    "volumes"
                ],
                "additionalProperties": false,
                "properties": {
                    "from": {
                        "type": "string",
                        "description": "Source node."
                    },
                    "to": {
                        "type": "string",
                        "description": "Target node."
                    },
                    "volumes": {
                        "type": "object",
                        "description": "Transform source, keyed by name.",
                        "additionalProperties": false,
                        "properties": {
                            "references": {
                                "oneOf": [
                                    {
                                        "$ref": "neuromaps_references.schema.json"
                                    },
                                    {
                                        "type": "null"
                                    }
                                ]
                            }
                        },
                        "patternProperties": {
                            "^[A-Za-z0-9_]+$": {
                                "allOf": [
                                    {
                                        "$ref": "neuromaps_volumes.schema.json"
                                    }
                                ]
                            }
                        }
                    }
                }
            }
        }
    }
}
